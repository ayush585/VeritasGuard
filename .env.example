MISTRAL_API_KEY=your_mistral_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
ENABLE_GOOGLE_SEARCH_FALLBACK=false
TAVILY_API_KEY=your_tavily_api_key_here
ENABLE_TAVILY_SEARCH_FALLBACK=true
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID_DEFAULT=your_elevenlabs_voice_id_here
# Optional JSON map: {"hi":"voice_id_1","ta":"voice_id_2","en":"voice_id_3"}
ELEVENLABS_VOICE_MAP={}
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
WHATSAPP_VALIDATE_SIGNATURE=true
WHATSAPP_MAX_WAIT_SECONDS=12
WHATSAPP_MEDIA_MAX_BYTES=4194304
WHATSAPP_MEDIA_TIMEOUT_SECONDS=8
WHATSAPP_RATE_LIMIT_WINDOW_SECONDS=60
WHATSAPP_RATE_LIMIT_MAX_REQUESTS=5
PIPELINE_DEADLINE_SECONDS=12
STAGE_BUDGET_LANGUAGE_SECONDS=0.8
STAGE_BUDGET_TRANSLATION_SECONDS=1.5
STAGE_BUDGET_CLAIM_SECONDS=1.5
STAGE_BUDGET_VERIFICATION_SECONDS=4.0
STAGE_BUDGET_SOURCE_SECONDS=4.0
STAGE_BUDGET_MEDIA_SECONDS=2.0
STAGE_BUDGET_CONTEXT_SECONDS=1.2
STAGE_BUDGET_EXPERT_SECONDS=1.5
STAGE_BUDGET_VERDICT_SECONDS=1.0
ENABLE_SOURCE_AGENT=true
ENABLE_MEDIA_AGENT=false
ENABLE_CONTEXT_AGENT=true
ENABLE_EXPERT_AGENT=false
DETERMINISTIC_OVERRIDE_THRESHOLD=0.5
DETERMINISTIC_STRONG_THRESHOLD=0.75
MISTRAL_QUERY_MAX_RETRIES=2
